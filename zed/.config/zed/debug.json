// Some example tasks for common languages.
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
	{
		"label": "Debug active Python file",
		"adapter": "Debugpy",
		"program": "$ZED_FILE",
		"request": "launch",
		"cwd": "$ZED_WORKTREE_ROOT",
	},
	{
		"label": "Debug active JavaScript file",
		"adapter": "JavaScript",
		"program": "$ZED_FILE",
		"request": "launch",
		"cwd": "$ZED_WORKTREE_ROOT",
		"type": "pwa-node",
	},
	{
		"label": "JavaScript debug terminal",
		"adapter": "JavaScript",
		"request": "launch",
		"cwd": "$ZED_WORKTREE_ROOT",
		"console": "integratedTerminal",
		"type": "pwa-node",
	},
	{
		"label": "Java Launch Debugger",
		"adapter": "Java",
		"request": "launch",
		// if your project has multiple entry points, specify the one to use:
		// "mainClass": "com.myorganization.myproject.MyMainClass",
		//
		// this effectively sets a breakpoint at your program entry:
		"stopOnEntry": false,
		// the working directory for the debug process
		"cwd": "$ZED_WORKTREE_ROOT",
	},
]
